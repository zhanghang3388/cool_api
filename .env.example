# Database
DB_USER=cool_api
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=cool_api
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# Server
APP_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
ALLOWED_ORIGINS=http://localhost:7631
PROVIDER_TIMEOUT_SECS=120
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=1
DB_ACQUIRE_TIMEOUT_SECS=10

# Admin (initial admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password-123

# Rate Limiting
# Default RPM limit for users (if not set in database)
DEFAULT_USER_RPM_LIMIT=60

# Global RPM limit across all users (optional, leave empty for no global limit)
# GLOBAL_RPM_LIMIT=10000
