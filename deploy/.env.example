# ================== required ==================

# Domains. Caddy provisions a Let's Encrypt cert for each of these on first
# start; point their A / AAAA records at this server's public IP *before*
# `docker compose up -d`, otherwise certificate issuance will fail.
WEB_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Email that Let's Encrypt uses for expiry reminders. Required.
ACME_EMAIL=you@example.com

# ---- Postgres ----
POSTGRES_USER=aethergate
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aethergate

# ---- Backend secrets ----
# Must match whatever value you started the system with — changing JWT_SECRET
# logs everyone out; changing ENCRYPTION_KEY makes saved channel API keys and
# payment credentials unreadable. Set once, guard carefully.
#
# Generate JWT_SECRET:    openssl rand -hex 32
# Generate ENCRYPTION_KEY: openssl rand -base64 32
JWT_SECRET=change-me-to-a-64-char-random-string
ENCRYPTION_KEY=change-me-base64-encoded-32-bytes

# Initial admin account (only applied on the very first start when no admins exist)
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change-me-after-first-login

# ================== optional ==================

JWT_TTL_HOURS=24
RUST_LOG=info,aethergate=info
