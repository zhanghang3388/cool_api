# Copy this file to .env and edit values for local development.
# figment loads config.toml first, then overrides with these env vars.

# HTTP bind address
BIND=0.0.0.0:3000

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aethergate

# Redis connection string
REDIS_URL=redis://127.0.0.1:6379

# JWT signing secret (>= 32 chars recommended)
JWT_SECRET=change-me-to-a-long-random-string

# Token time-to-live in hours
JWT_TTL_HOURS=24

# 32-byte key for encrypting channel API keys at rest (base64)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-me-base64-encoded-32-bytes

# Logging (info by default; set `debug` or `aethergate=trace` for more detail)
RUST_LOG=info,aethergate=debug
